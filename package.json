{
	"name": "@zenfs/playground",
	"version": "0.0.0",
	"description": "A playground for ZenFS",
	"main": "dist/index.js",
	"type": "module",
	"scripts": {
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "tsc -p tsconfig.json --noEmit && eslint src",
		"build": "tsx build.ts",
		"dev": "tsx build.ts -m dev"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zen-fs/playground.git"
	},
	"keywords": [
		"zenfs",
		"filesystem"
	],
	"author": "James Prevett <jp@jamespre.dev> (https://jamespre.dev)",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/zen-fs/playground/issues"
	},
	"homepage": "https://github.com/zen-fs/playground#readme",
	"dependencies": {
		"@endo/module-source": "^1.4.0",
		"@types/jquery": "^3.5.31",
		"@xterm/addon-fit": "^0.10.0",
		"@xterm/addon-web-links": "^0.11.0",
		"@xterm/xterm": "^5.5.0",
		"@zenfs/archives": "^1.3.1",
		"@zenfs/core": "^2.5.0",
		"@zenfs/dom": "^1.2.7",
		"chalk": "^5.3.0",
		"jquery": "^3.7.1",
		"kerium": "^1.3.8",
		"ses": "^1.15.0",
		"utilium": "^2.0.0"
	},
	"devDependencies": {
		"@types/node": "^25.3.3",
		"esbuild": "^0.25.0",
		"eslint": "^9.12.0",
		"globals": "^16.0.0",
		"prettier": "^3.3.3",
		"tsx": "^4.19.1",
		"typescript": "^6.0.0",
		"typescript-eslint": "^8.58.0"
	}
}
